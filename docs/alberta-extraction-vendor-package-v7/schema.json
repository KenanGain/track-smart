{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "tracksmart://schemas/alberta-carrier-profile.v1.schema.json",
  "title": "Alberta Carrier Profile Extraction (v1)",
  "description": "Output shape produced by the Alberta Carrier Profile PDF extractor. Field names match the existing TrackSmart frontend (src/pages/inspections/NscAbPullByPull.tsx + NscAbPerformanceHistory.tsx). One uploaded PDF = one entry in the AB pull-by-pull table.",
  "type": "object",
  "required": ["source", "carrier", "pull"],
  "additionalProperties": false,
  "properties": {

    "warnings": {
      "type": "array",
      "description": "Soft validation issues (cross-field drift, OCR confidence, unknown form version).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code":    { "type": "string", "description": "Stable enum, e.g. RFACTOR_DRIFT, CONTRIBUTION_DRIFT, FORM_VERSION_UNKNOWN, OCR_LOW_CONFIDENCE, ANALYSIS_TOTAL_DRIFT" },
          "message": { "type": "string" },
          "field":   { "type": ["string", "null"], "description": "Dotted JSON path of the affected field" },
          "page":    { "type": ["integer", "null"], "minimum": 1 }
        }
      }
    },

    "source": {
      "type": "object",
      "description": "PDF metadata (audit trail). Most values come from each Part's banner: 'Profile Period Start/End', 'Date Printed', 'Pages X to Y'.",
      "additionalProperties": false,
      "required": ["fileName", "extractedAt"],
      "properties": {
        "fileName":            { "type": "string", "description": "Source PDF filename" },
        "datePrinted":         { "type": ["string", "null"], "format": "date", "description": "Cover/Part 2-6 banner — 'Date Printed: YYYY MMM DD'" },
        "profilePeriodStart":  { "type": ["string", "null"], "format": "date", "description": "Cover — 'Profile Period Start' (typically reportDate − 24 months)" },
        "profilePeriodEnd":    { "type": ["string", "null"], "format": "date", "description": "Cover — 'Profile Period End' (= reportDate)" },
        "twelveMonthReportAs": { "type": ["string", "null"], "format": "date", "description": "Part 1 — '12-month Report as of: YYYY MMM DD'" },
        "formVersion":         { "type": ["string", "null"], "description": "Footer code, when present" },
        "pageCount":           { "type": "integer" },
        "extractedAt":         { "type": "string", "format": "date-time" }
      }
    },

    "carrier": {
      "type": "object",
      "description": "Carrier identity from Part 1 — Carrier Information. Populates the AB Carrier Profile sticky.",
      "additionalProperties": false,
      "required": ["nscNumber", "legalName"],
      "properties": {
        "nscNumber":            { "type": "string", "pattern": "^[A-Z]{2}\\d{3}-\\d{4}$", "description": "Cover/Part 1 — 'NSC Number' (e.g. 'AB243-8992')" },
        "mvidNumber":           { "type": ["string", "null"], "description": "Part 1 — 'MVID Number' (e.g. '0854-32599')" },
        "legalName":            { "type": "string", "description": "Cover/Part 1 — 'Carrier Name'" },
        "address": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "street":    { "type": ["string", "null"] },
            "city":      { "type": ["string", "null"] },
            "province":  { "type": ["string", "null"], "description": "Two-letter Canadian province code" },
            "postalCode":{ "type": ["string", "null"] },
            "country":   { "type": ["string", "null"] }
          }
        },
        "safetyFitnessRating":  { "type": ["string", "null"], "enum": ["Excellent", "Satisfactory", "Satisfactory Unaudited", "Conditional", "Unsatisfactory", null], "description": "Part 1 — 'Safety Fitness Rating'" },
        "operatingStatus":      { "type": ["string", "null"], "description": "Part 1 — 'Operating Status' (e.g. 'Federal', 'Provincial')" },
        "fleetRange":           { "type": ["string", "null"], "description": "Part 1 — 'Fleet Range' (e.g. '5-9', '10-49', '11')" },
        "fleetType":            { "type": ["string", "null"], "enum": ["Truck", "Bus", "Mixed", null], "description": "Part 1 — 'Fleet Type'" },
        "certificateNumber":    { "type": ["string", "null"], "description": "Part 1 (newer format only) — 'Certificate Number' from the SAFETY FITNESS CERTIFICATE block (e.g. '002061190')" },
        "certificateEffectiveDate":{ "type": ["string", "null"], "format": "date", "description": "Part 1 (newer format only) — 'Effective Date' on the safety fitness certificate" },
        "certificateExpiryDate":{ "type": ["string", "null"], "format": "date", "description": "Part 1 (newer format only) — 'Expiry Date' on the safety fitness certificate" }
      }
    },

    "pull": {
      "type": "object",
      "description": "Per-pull record. One uploaded PDF = one entry in the AB pull-by-pull table.",
      "additionalProperties": false,
      "required": [
        "reportDate", "rFactor",
        "contributions",
        "monitoringStage",
        "avgFleet", "currentFleet",
        "totalConvictions", "totalCvsaInspections", "totalCollisions", "totalViolations",
        "convictionAnalysis", "convictionSummary", "convictionDetails",
        "cvsaDefectAnalysis", "cvsaSummary", "cvsaDetails",
        "collisionTotals", "collisionSummary", "collisionDetails",
        "violationAnalysis", "violationSummary", "violationDetails",
        "monitoring"
      ],
      "properties": {

        "reportDate":           { "type": "string", "format": "date", "description": "Frontend pullDate. Source: source.datePrinted (or source.profilePeriodEnd when datePrinted absent)" },
        "periodLabel":          { "type": ["string", "null"], "description": "Derived display label, e.g. 'Mar 6/26'. Frontend: pullDate" },
        "windowLabel":          { "type": ["string", "null"], "description": "Derived display label, e.g. 'Mar 2024 → Mar 2026'. Frontend: windowLabel" },
        "windowStart":          { "type": ["string", "null"], "format": "date", "description": "= source.profilePeriodStart" },
        "windowEnd":            { "type": ["string", "null"], "format": "date", "description": "= source.profilePeriodEnd" },

        "rFactor":              { "type": "number", "description": "Part 1 — 'R-Factor Score'. Frontend: rFactor (also drives status badge)" },

        "contributions": {
          "type": "object",
          "description": "Part 1 — 'Contribution to R-Factor' three rows. Sum should be ~100 (±0.5).",
          "additionalProperties": false,
          "required": ["conviction", "inspection", "collision"],
          "properties": {
            "conviction": { "type": "number", "description": "% from Convictions" },
            "inspection": { "type": "number", "description": "% from CVSA Inspections" },
            "collision":  { "type": "number", "description": "% from Reportable Collisions" }
          }
        },

        "monitoringStage":      { "type": ["integer", "null"], "minimum": 1, "maximum": 4, "description": "Part 1 — 'Carrier's Monitoring Stage (1 to 4)'. Null when no stage assigned." },
        "carriersAtStageOrAbove":{ "type": ["integer", "null"], "description": "Part 1 — 'Total number of carriers at the same stage or greater'" },
        "totalAlbertaNscCarriers":{ "type": ["integer", "null"], "description": "Part 1 — 'NSC carriers in Alberta with Safety Fitness Certificates'" },

        "avgFleet":             { "type": "integer", "description": "Part 1 — 'NSC Fleet Size on … Average'. Frontend: AvgFleet column" },
        "currentFleet":         { "type": "integer", "description": "Part 1 — 'NSC Fleet Size on … Current'. Frontend: Current column" },

        "totalConvictions":     { "type": "integer", "description": "Part 2 banner — 'TOTALS: CONVICTIONS:'. Frontend: convictions" },
        "totalConvictionDocuments":{ "type": ["integer", "null"], "description": "Part 2 banner — 'TOTALS: DOCUMENTS:'" },
        "totalAdminPenalties":  { "type": ["integer", "null"], "description": "Newer format only (Part 3 — Administrative Penalty Information) banner — 'TOTALS: PENALTIES:'. Frontend: adminPenalties." },
        "totalAdminPenaltyDocuments":{ "type": ["integer", "null"], "description": "Newer format only — Part 3 banner 'TOTALS: DOCUMENTS:'" },
        "totalCvsaInspections": { "type": "integer", "description": "Part 3 banner (older format) / Part 4 banner (newer format) — 'TOTALS: CVSA INSPECTIONS:'. Frontend: cvsaInspections / inspections" },
        "totalCvsaDocuments":   { "type": ["integer", "null"], "description": "CVSA section banner — 'TOTALS: DOCUMENTS:'" },
        "totalCollisions":      { "type": "integer", "description": "Collision section — Σ collisionTotals[].count. Frontend: reportableCollisions" },
        "totalViolations":      { "type": "integer", "description": "Violation section banner — 'TOTALS: OFFENCES:'. Distinct from admin penalties (newer format Part 3); AB violations carry no NSC points." },
        "totalViolationDocuments":{ "type": ["integer", "null"], "description": "Violation section banner — 'TOTALS: DOCUMENTS:'" },

        "convictionAnalysis": {
          "type": "array",
          "description": "Part 2 — Conviction Analysis table. Always 16 rows in the same order. Σ count === totalConvictions. Frontend: AB_CONV_GROUPS.",
          "minItems": 16,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/groupAnalysisRow" }
        },
        "convictionSummary": {
          "type": "array",
          "description": "Part 2 — Conviction Summary list (one row per conviction). Frontend: AB_CONV_SUMMARY.",
          "items": { "$ref": "#/$defs/convictionSummaryRow" }
        },
        "convictionDetails": {
          "type": "array",
          "description": "Part 2 — Conviction Details list (one entry per conviction). Frontend: AB_CONV_DETAILS.",
          "items": { "$ref": "#/$defs/convictionDetailRow" }
        },

        "cvsaDefectAnalysis": {
          "type": "array",
          "description": "Part 3 — CVSA Defect Analysis table. The original Alberta template lists 19 standard CCMTA categories; some report runs (2019+) add additional rows (e.g. category 20 'Driver's Seat (Missing)'). Preserve PDF order and emit one entry per printed row.",
          "minItems": 19,
          "items": { "$ref": "#/$defs/cvsaDefectRow" }
        },
        "cvsaDefectTotals": {
          "type": "object",
          "description": "Part 3 — Grand Total Defects row (foot of the analysis table).",
          "additionalProperties": false,
          "required": ["oos", "req", "total"],
          "properties": {
            "oos":   { "type": "integer", "description": "Σ Out of Service (O) flags" },
            "req":   { "type": "integer", "description": "Σ Requires Attention (X) flags" },
            "total": { "type": "integer", "description": "Σ defects across all categories" }
          }
        },
        "cvsaSummary": {
          "type": "array",
          "description": "Part 3 — CVSA Inspection Summary list. Frontend: AB_CVSA_SUMMARY.",
          "items": { "$ref": "#/$defs/cvsaSummaryRow" }
        },
        "cvsaDetails": {
          "type": "array",
          "description": "Part 3 — CVSA Inspection Details list (one entry per inspection, with vehicles + defects). Frontend: AB_CVSA_DETAILS.",
          "items": { "$ref": "#/$defs/cvsaDetailRow" }
        },

        "collisionTotals": {
          "type": "array",
          "description": "Part 4 — Collision Information totals table (Property Damage / Injury / Fatal × count, non-preventable, preventable-or-not-evaluated, points). Always 3 rows. Frontend: AB_COLLISION_TOTALS.",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/collisionTotalRow" }
        },
        "collisionSummary": {
          "type": "array",
          "description": "Part 4 — Collision Summary list. Frontend: AB_COLLISION_SUMMARY.",
          "items": { "$ref": "#/$defs/collisionSummaryRow" }
        },
        "collisionDetails": {
          "type": "array",
          "description": "Part 4 — Collision Details list. Frontend: AB_COLLISION_DETAILS.",
          "items": { "$ref": "#/$defs/collisionDetailRow" }
        },

        "violationAnalysis": {
          "type": "array",
          "description": "Part 5 — Violation Group Analysis table. Always 16 rows in the same order as convictionAnalysis. Σ count === totalViolations. Frontend: AB_VIOL_GROUPS.",
          "minItems": 16,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/groupAnalysisRow" }
        },
        "violationSummary": {
          "type": "array",
          "description": "Part 5 — Violation Summary list. Frontend: AB_VIOL_SUMMARY.",
          "items": { "$ref": "#/$defs/violationSummaryRow" }
        },
        "violationDetails": {
          "type": "array",
          "description": "Part 5 — Violation Details list. Each entry contains 1+ offences. Frontend: AB_VIOL_DETAILS.",
          "items": { "$ref": "#/$defs/violationDetailRow" }
        },

        "adminPenaltyAnalysis": {
          "type": "array",
          "description": "Newer format only — Part 3 (Administrative Penalty Information) Group Analysis table. Same 16 CCMTA group buckets as the conviction/violation tables. Σ count === totalAdminPenalties. Optional in older-format extractions (omit field or emit empty array).",
          "minItems": 0,
          "items": { "$ref": "#/$defs/groupAnalysisRow" }
        },
        "adminPenaltySummary": {
          "type": "array",
          "description": "Newer format only — Part 3 Administrative Penalty Summary list (one row per penalty).",
          "items": { "$ref": "#/$defs/adminPenaltySummaryRow" }
        },
        "adminPenaltyDetails": {
          "type": "array",
          "description": "Newer format only — Part 3 Administrative Penalty Details list (one block per penalty, with Act/Section, CCMTA code, dollar amount).",
          "items": { "$ref": "#/$defs/adminPenaltyDetailRow" }
        },

        "monitoring": {
          "type": "object",
          "description": "Part 6 — Monitoring Information.",
          "additionalProperties": false,
          "required": ["industry", "thresholds", "summary", "details"],
          "properties": {
            "industry": {
              "type": "object",
              "description": "Part 6 — Industry Monitoring Information block.",
              "additionalProperties": false,
              "required": ["asOf", "fleetRange", "fleetType", "avgRFactor"],
              "properties": {
                "asOf":         { "type": "string", "format": "date" },
                "fleetRange":   { "type": "string", "description": "Should equal carrier.fleetRange" },
                "fleetType":    { "type": "string", "description": "TRK / BUS / MIXED" },
                "avgRFactor":   { "type": "number" },
                "avgConvPts":   { "type": ["number", "null"] },
                "avgOosDef":    { "type": ["number", "null"] },
                "avgTotalDef":  { "type": ["number", "null"] },
                "avgOosVeh":    { "type": ["number", "null"] },
                "avgFailure":   { "type": ["number", "null"] },
                "avgCollPts":   { "type": ["number", "null"] }
              }
            },
            "thresholds": {
              "type": "array",
              "description": "Part 6 — Monitoring Stage R-Factor Thresholds for the carrier's fleet range. Always 4 rows (Stage 1-4).",
              "minItems": 4,
              "maxItems": 4,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["stage", "lowerBound", "upperBound"],
                "properties": {
                  "stage":      { "type": "integer", "minimum": 1, "maximum": 4 },
                  "lowerBound": { "type": "number" },
                  "upperBound": { "type": ["number", "null"], "description": "Null for the open-ended top stage ('X.XXX and higher')" },
                  "label":      { "type": "string", "description": "Original label, e.g. 'Stage 4'" },
                  "rangeText":  { "type": "string", "description": "Original range text, e.g. '2.000 and higher'" }
                }
              }
            },
            "summary": {
              "type": "array",
              "description": "Part 6 — 24-month Monitoring Summary table. One row per month (newest first). Latest row's score should equal pull.rFactor.",
              "items": { "$ref": "#/$defs/monitoringSummaryRow" }
            },
            "details": {
              "type": "array",
              "description": "Part 6 — Monitoring Details table (component metrics per month).",
              "items": { "$ref": "#/$defs/monitoringDetailRow" }
            }
          }
        }
      }
    }
  },

  "$defs": {

    "groupAnalysisRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "count"],
      "properties": {
        "group":   { "type": "string", "description": "CCMTA group name (e.g. 'Speeding', 'Hours of Service', 'Miscellaneous')" },
        "count":   { "type": "integer", "minimum": 0 },
        "pctText": { "type": ["string", "null"], "description": "Original % text as printed (e.g. '100.0%') or null when count === 0" }
      }
    },

    "convictionSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction"],
      "properties": {
        "seq":         { "type": "integer", "minimum": 1 },
        "date":        { "type": "string", "description": "Offence date as printed, e.g. '2022 FEB 25'" },
        "dateIso":     { "type": ["string", "null"], "format": "date" },
        "document":    { "type": "string", "description": "e.g. 'TVT E18718140A'" },
        "docket":      { "type": ["string", "null"] },
        "jurisdiction":{ "type": "string", "description": "Two-letter province code, e.g. 'AB', 'ON'" },
        "vehicle":     { "type": ["string", "null"], "description": "Plate + jurisdiction, e.g. 'A24172 AB'" },
        "driverName":  { "type": ["string", "null"] },
        "offence":     { "type": "string", "description": "Short offence description" },
        "points":      { "type": "integer", "minimum": 0 }
      }
    },

    "convictionDetailRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction", "offence"],
      "properties": {
        "seq":             { "type": "integer", "minimum": 1 },
        "date":            { "type": "string" },
        "dateIso":         { "type": ["string", "null"], "format": "date" },
        "time":            { "type": ["string", "null"], "description": "HH:MM" },
        "document":        { "type": "string" },
        "docket":          { "type": ["string", "null"] },
        "jurisdiction":    { "type": "string" },
        "dateEntered":     { "type": ["string", "null"] },
        "issuingAgency":   { "type": ["string", "null"] },
        "location":        { "type": ["string", "null"] },
        "driver":          { "type": ["string", "null"], "description": "Driver name + licence + jur as printed" },
        "vehicle":         { "type": ["string", "null"] },
        "commodity":       { "type": ["string", "null"] },
        "actSection":      { "type": ["string", "null"] },
        "offence":         { "type": "string", "description": "Act description" },
        "ccmtaCode":       { "type": ["string", "null"], "description": "e.g. '317 FAIL TO OBEY DEVICE'" },
        "convictionVehicle":{ "type": ["string", "null"] },
        "convictionDate":  { "type": ["string", "null"] },
        "activePoints":    { "type": "integer", "minimum": 0 }
      }
    },

    "cvsaDefectRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "label"],
      "properties": {
        "code":    { "type": "string", "description": "Category number 1-19" },
        "label":   { "type": "string" },
        "oos":     { "type": ["integer", "null"], "minimum": 0 },
        "req":     { "type": ["integer", "null"], "minimum": 0 },
        "total":   { "type": ["integer", "null"], "minimum": 0 },
        "pctText": { "type": ["string", "null"] }
      }
    },

    "cvsaSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction", "level", "result"],
      "properties": {
        "seq":         { "type": "integer", "minimum": 1 },
        "date":        { "type": "string" },
        "dateIso":     { "type": ["string", "null"], "format": "date" },
        "document":    { "type": "string" },
        "jurisdiction":{ "type": "string" },
        "agency":      { "type": ["string", "null"] },
        "plate":       { "type": ["string", "null"] },
        "plateJur":    { "type": ["string", "null"] },
        "level":       { "type": "integer", "minimum": 1, "maximum": 5 },
        "result":      { "type": "string", "enum": ["Passed", "Out of Service", "Requires Attention"] }
      }
    },

    "cvsaVehicle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "plate", "jurisdiction"],
      "properties": {
        "type":         { "type": "string", "description": "P (Power Unit), ST (Semi-Trailer), T (Trailer), B (Bus), …" },
        "plate":        { "type": "string" },
        "jurisdiction": { "type": "string" },
        "vin":          { "type": ["string", "null"] },
        "year":         { "type": ["string", "null"] },
        "make":         { "type": ["string", "null"] },
        "decal":        { "type": ["string", "null"], "description": "CVSA Decal #" }
      }
    },

    "cvsaDefect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "vehicleIndex", "kind"],
      "properties": {
        "category":     { "type": "string", "description": "Category number + label, e.g. '9 - Lighting Devices'" },
        "vehicleIndex": { "type": "integer", "minimum": 1, "description": "1-based index into cvsaDetails[i].vehicles" },
        "kind":         { "type": "string", "enum": ["OOS", "REQ"], "description": "OOS = Out of Service (O), REQ = Requires Attention (X)" }
      }
    },

    "cvsaDetailRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction", "level", "result", "vehicles"],
      "properties": {
        "seq":         { "type": "integer", "minimum": 1 },
        "date":        { "type": "string" },
        "dateIso":     { "type": ["string", "null"], "format": "date" },
        "time":        { "type": ["string", "null"] },
        "document":    { "type": "string" },
        "jurisdiction":{ "type": "string" },
        "level":       { "type": "integer", "minimum": 1, "maximum": 5 },
        "result":      { "type": "string", "enum": ["Passed", "Out of Service", "Requires Attention"] },
        "dateEntered": { "type": ["string", "null"] },
        "agency":      { "type": ["string", "null"] },
        "location":    { "type": ["string", "null"] },
        "driver":      { "type": ["string", "null"] },
        "vehicles":    { "type": "array", "items": { "$ref": "#/$defs/cvsaVehicle" } },
        "defects":     { "type": "array", "items": { "$ref": "#/$defs/cvsaDefect" } }
      }
    },

    "collisionTotalRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "count", "nonPreventable", "preventableOrNotEvaluated", "points"],
      "properties": {
        "type":                      { "type": "string", "enum": ["Property Damage", "Injury", "Fatal"] },
        "count":                     { "type": "integer", "minimum": 0 },
        "nonPreventable":            { "type": "integer", "minimum": 0 },
        "preventableOrNotEvaluated": { "type": "integer", "minimum": 0 },
        "points":                    { "type": "integer", "minimum": 0 }
      }
    },

    "collisionSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction", "severity", "points"],
      "properties": {
        "seq":         { "type": "integer", "minimum": 1 },
        "date":        { "type": "string" },
        "dateIso":     { "type": ["string", "null"], "format": "date" },
        "document":    { "type": "string" },
        "jurisdiction":{ "type": "string" },
        "plate":       { "type": ["string", "null"] },
        "plateJur":    { "type": ["string", "null"] },
        "driver":      { "type": ["string", "null"] },
        "status":      { "type": ["string", "null"], "description": "e.g. 'Not Evaluated', 'Evaluated'" },
        "preventable": { "type": ["string", "null"], "description": "'Preventable', 'Non-Preventable', or empty when not evaluated" },
        "severity":    { "type": "string", "enum": ["Damage", "Injury", "Fatal"] },
        "points":      { "type": "integer", "minimum": 0 }
      }
    },

    "collisionDetailRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction", "severity", "activePoints"],
      "properties": {
        "seq":         { "type": "integer", "minimum": 1 },
        "date":        { "type": "string" },
        "dateIso":     { "type": ["string", "null"], "format": "date" },
        "time":        { "type": ["string", "null"] },
        "document":    { "type": "string" },
        "jurisdiction":{ "type": "string" },
        "plate":       { "type": ["string", "null"] },
        "plateJur":    { "type": ["string", "null"] },
        "severity":    { "type": "string", "enum": ["Damage", "Injury", "Fatal"] },
        "assessment":  { "type": ["string", "null"], "description": "e.g. 'Not Evaluated', 'Preventable', 'Non-Preventable'" },
        "driver":      { "type": ["string", "null"] },
        "location":    { "type": ["string", "null"] },
        "vehicle":     { "type": ["string", "null"], "description": "Year + make, e.g. '2016 FREIGHTLINER'" },
        "vin":         { "type": ["string", "null"] },
        "activePoints":{ "type": "integer", "minimum": 0 }
      }
    },

    "violationSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction"],
      "properties": {
        "seq":         { "type": "integer", "minimum": 1 },
        "date":        { "type": "string" },
        "dateIso":     { "type": ["string", "null"], "format": "date" },
        "document":    { "type": "string" },
        "jurisdiction":{ "type": "string" },
        "plate":       { "type": ["string", "null"] },
        "plateJur":    { "type": ["string", "null"] },
        "driverName":  { "type": ["string", "null"] },
        "offence":     { "type": ["string", "null"], "description": "Short offence text — first offence on the record" }
      }
    },

    "violationOffence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["num", "actSection", "ccmtaCode", "ccmtaLabel"],
      "properties": {
        "num":        { "type": "integer", "minimum": 1, "description": "1-based offence number within the record" },
        "actSection": { "type": "string" },
        "actDesc":    { "type": ["string", "null"] },
        "ccmtaCode":  { "type": "string", "description": "e.g. '1202'" },
        "ccmtaLabel": { "type": "string", "description": "e.g. 'Miscellaneous' — must match a violationAnalysis[].group" },
        "vehicle":    { "type": ["string", "null"] },
        "text":       { "type": ["string", "null"], "description": "Officer's note text" }
      }
    },

    "violationDetailRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction", "offences"],
      "properties": {
        "seq":           { "type": "integer", "minimum": 1 },
        "date":          { "type": "string" },
        "dateIso":       { "type": ["string", "null"], "format": "date" },
        "time":          { "type": ["string", "null"] },
        "document":      { "type": "string" },
        "jurisdiction":  { "type": "string" },
        "dateEntered":   { "type": ["string", "null"] },
        "issuingAgency": { "type": ["string", "null"] },
        "location":      { "type": ["string", "null"] },
        "driver":        { "type": ["string", "null"] },
        "vehicle":       { "type": ["string", "null"] },
        "commodity":     { "type": ["string", "null"] },
        "offences":      { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/violationOffence" } }
      }
    },

    "monitoringSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["monthEnd", "type", "avgFleet", "currentFleet"],
      "properties": {
        "monthEnd":     { "type": "string", "description": "e.g. '2019 DEC'" },
        "monthEndIso":  { "type": ["string", "null"], "format": "date" },
        "type":         { "type": "string", "enum": ["TRK", "BUS", "MIXED"] },
        "trkPct":       { "type": ["string", "null"] },
        "busPct":       { "type": ["string", "null"] },
        "avgFleet":     { "type": "integer", "minimum": 0 },
        "currentFleet": { "type": "integer", "minimum": 0 },
        "score":        { "type": ["number", "null"], "description": "R-Factor score for that month. Null when 'No Data' is printed." },
        "scoreText":    { "type": ["string", "null"], "description": "Original text, e.g. '2.314' or 'No Data'" },
        "convPctText":  { "type": ["string", "null"] },
        "inspPctText":  { "type": ["string", "null"] },
        "collPctText":  { "type": ["string", "null"] },
        "stage":        { "type": ["integer", "null"], "minimum": 1, "maximum": 4 }
      }
    },

    "monitoringDetailRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["monthEnd", "avgFleet"],
      "properties": {
        "monthEnd":      { "type": "string" },
        "monthEndIso":   { "type": ["string", "null"], "format": "date" },
        "avgFleet":      { "type": "integer", "minimum": 0 },
        "convPtsPerVeh": { "type": ["number", "null"], "description": "Conviction points per vehicle (12-mo)" },
        "totalInspections":{ "type": ["integer", "null"], "minimum": 0 },
        "oosDefPerInsp": { "type": ["number", "null"] },
        "totalDefPerInsp":{ "type": ["number", "null"] },
        "oosPctText":    { "type": ["string", "null"] },
        "oosPerVeh":     { "type": ["number", "null"] },
        "failureRate":   { "type": ["number", "null"] },
        "collPtsPerVeh": { "type": ["number", "null"] }
      }
    },

    "adminPenaltySummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction"],
      "properties": {
        "seq":         { "type": "integer", "minimum": 1 },
        "date":        { "type": "string" },
        "dateIso":     { "type": ["string", "null"], "format": "date" },
        "document":    { "type": "string" },
        "jurisdiction":{ "type": "string" },
        "plate":       { "type": ["string", "null"] },
        "plateJur":    { "type": ["string", "null"] },
        "driverName":  { "type": ["string", "null"] },
        "offence":     { "type": ["string", "null"] },
        "amount":      { "type": ["number", "null"], "description": "Penalty dollar amount, when printed" }
      }
    },

    "adminPenaltyDetailRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "date", "document", "jurisdiction"],
      "properties": {
        "seq":           { "type": "integer", "minimum": 1 },
        "date":          { "type": "string" },
        "dateIso":       { "type": ["string", "null"], "format": "date" },
        "time":          { "type": ["string", "null"] },
        "document":      { "type": "string" },
        "jurisdiction":  { "type": "string" },
        "dateEntered":   { "type": ["string", "null"] },
        "issuingAgency": { "type": ["string", "null"] },
        "location":      { "type": ["string", "null"] },
        "driver":        { "type": ["string", "null"] },
        "vehicle":       { "type": ["string", "null"] },
        "actSection":    { "type": ["string", "null"] },
        "ccmtaCode":     { "type": ["string", "null"] },
        "ccmtaLabel":    { "type": ["string", "null"], "description": "Must match a row in adminPenaltyAnalysis[].group when present" },
        "amount":        { "type": ["number", "null"] },
        "text":          { "type": ["string", "null"] }
      }
    }
  }
}
