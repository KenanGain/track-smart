{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "tracksmart://schemas/cvor-extraction.schema.json",
  "title": "CVOR PDF Extraction",
  "description": "Output shape produced by the CVOR PDF extractor. Field names match the TrackSmart frontend components (Carrier Profile + cvorPeriodicReports + CVOR Inspections list).",
  "type": "object",
  "required": ["source", "carrier", "pull", "inspectionEvents"],
  "additionalProperties": false,
  "properties": {

    "source": {
      "type": "object",
      "description": "PDF metadata (audit trail).",
      "additionalProperties": false,
      "required": ["fileName", "extractedAt"],
      "properties": {
        "fileName":     { "type": "string", "description": "Source PDF filename" },
        "orderNumber":  { "type": ["string", "null"], "description": "p.1 — Order #" },
        "searchDate":   { "type": ["string", "null"], "format": "date-time", "description": "p.1 — Search Date and Time" },
        "formVersion":  { "type": ["string", "null"], "description": "Footer — e.g. SR-LV-029A (2021/10)" },
        "pageCount":    { "type": "integer" },
        "extractedAt":  { "type": "string", "format": "date-time" }
      }
    },

    "carrier": {
      "type": "object",
      "description": "Carrier identity — populates the Carrier Profile (sticky, only updated on first upload or when the operator changes legal info).",
      "additionalProperties": false,
      "required": ["cvorNumber", "legalName"],
      "properties": {
        "cvorNumber":         { "type": "string", "pattern": "^\\d{3}-?\\d{3}-?\\d{3}$", "description": "p.1 — CVOR / RIN # (frontend: cvorNumber)" },
        "legalName":          { "type": "string", "description": "p.1 — Client Name (frontend: legalName)" },
        "operatingAs":        { "type": ["string", "null"], "description": "p.1 — Operating As (frontend: dbaName)" },
        "address": {
          "type": "object",
          "description": "p.1 — Address (multi-line block parsed)",
          "additionalProperties": false,
          "properties": {
            "street":  { "type": ["string", "null"] },
            "city":    { "type": ["string", "null"] },
            "state":   { "type": ["string", "null"] },
            "zip":     { "type": ["string", "null"] },
            "country": { "type": ["string", "null"] }
          }
        },
        "phone":              { "type": ["string", "null"], "description": "p.1 — Phone #" },
        "mobile":             { "type": ["string", "null"], "description": "p.1 — Mobile #" },
        "fax":                { "type": ["string", "null"], "description": "p.1 — Fax #" },
        "email":              { "type": ["string", "null"], "description": "p.1 — Email" },
        "usDotNumber":        { "type": ["string", "null"], "description": "p.1 — US DOT #" },
        "cvorStatus":         { "type": "string", "enum": ["Registered", "Cancelled", "Surrendered", "Suspended"], "description": "p.1 — CVOR Status" },
        "originalIssueDate":  { "type": "string", "format": "date", "description": "p.1 — Original Issue Date" },
        "safetyRating":       { "type": "string", "enum": ["Excellent", "Satisfactory", "Satisfactory-Unaudited", "Conditional", "Unsatisfactory"], "description": "p.1 — Carrier Safety Rating" },
        "vehicleTypes":       { "type": "array", "items": { "type": "string" }, "description": "p.1 — Type of Commercial Vehicle (multi-select)" },
        "dangerousGoods":     { "type": "boolean", "description": "p.1 — Dangerous Goods (Yes/No → bool)" }
      }
    },

    "pull": {
      "type": "object",
      "description": "Per-pull record — one entry per uploaded PDF. Maps 1-to-1 to CvorPeriodicReport in src/pages/inspections/inspectionsData.ts.",
      "additionalProperties": false,
      "required": ["reportDate", "rating", "colContrib", "conContrib", "insContrib"],
      "properties": {

        "reportDate":           { "type": "string", "format": "date", "description": "p.1 — Search Date and Time → ISO date (frontend: reportDate)" },
        "periodLabel":          { "type": "string", "description": "Derived display label, e.g. 'Apr 2/26' (frontend: periodLabel)" },
        "effectiveDate":        { "type": "string", "format": "date", "description": "p.1 — Start Date" },
        "expiryDate":           { "type": "string", "format": "date", "description": "p.1 — Expiry Date" },
        "windowStart":          { "type": "string", "format": "date", "description": "Derived: reportDate − 24 months" },
        "windowEnd":            { "type": "string", "format": "date", "description": "= reportDate" },

        "rating":               { "type": "number", "description": "p.2 — Overall Violation Rate % (frontend: rating)" },

        "colContrib":           { "type": "number", "description": "p.2 — Performance Summary → Collision → % Overall Contribution (frontend: colContrib)" },
        "conContrib":           { "type": "number", "description": "p.2 — Performance Summary → Conviction → % Overall Contribution (frontend: conContrib)" },
        "insContrib":           { "type": "number", "description": "p.2 — Performance Summary → Inspection → % Overall Contribution (frontend: insContrib)" },

        "colPctOfThresh":       { "type": "number", "description": "p.2 — Performance Summary → Collision → % of set Threshold (frontend: colPctOfThresh)" },
        "conPctOfThresh":       { "type": "number", "description": "p.2 — Performance Summary → Conviction → % of set Threshold (frontend: conPctOfThresh)" },
        "insPctOfThresh":       { "type": "number", "description": "p.2 — Performance Summary → Inspection → % of set Threshold (frontend: insPctOfThresh)" },

        "collisionEvents":      { "type": "integer", "description": "p.1 — Total # of Collisions (frontend: collisionEvents)" },
        "collWithPoints":       { "type": "integer", "description": "p.1 — # of Collisions with points (frontend: collWithPoints)" },
        "collWithoutPoints":    { "type": "integer", "description": "p.1 — # of Collisions not pointed (frontend: collWithoutPoints)" },
        "totalCollisionPoints": { "type": "integer", "description": "p.2 — Collision Breakdown → Total row → # of Points (frontend: totalCollisionPoints)" },

        "convictionEvents":     { "type": "integer", "description": "p.1 — Total # of convictions (frontend: convictionEvents)" },
        "convictionPoints":     { "type": "integer", "description": "p.2/p.3 — Conviction Breakdown → Total row → # of Points (frontend: convictionPoints)" },

        "oosOverall":           { "type": "number", "description": "p.2 — Overall Out of Service % (frontend: oosOverall)" },
        "oosVehicle":           { "type": "number", "description": "p.2 — Vehicle Out of Service % (frontend: oosVehicle)" },
        "oosDriver":            { "type": "number", "description": "p.2 — Driver Out of Service % (frontend: oosDriver)" },

        "trucks":               { "type": "integer", "description": "p.1 — # of Commercial Vehicles (frontend: trucks)" },
        "drivers":              { "type": "integer", "description": "p.1 — # of Drivers" },

        "onMiles":              { "type": "number", "description": "p.1 — Ontario Kms Travelled (frontend: onMiles — stored as kms; UI converts)" },
        "canadaMiles":          { "type": "number", "description": "p.1 — Rest of Canada Kms Travelled (frontend: canadaMiles)" },
        "usMexicoMiles":        { "type": "number", "description": "p.1 — US/Mexico Kms Travelled" },
        "totalMiles":           { "type": "number", "description": "p.1 — Total Kms Travelled (frontend: totalMiles)" },

        "inspectionsByLevel": {
          "type": "object",
          "description": "p.2 — # of Inspections by level. Drives the 'CVOR Rating Comparison' L1-L5 cards.",
          "additionalProperties": false,
          "properties": {
            "l1": { "type": "integer" }, "l2": { "type": "integer" },
            "l3": { "type": "integer" }, "l4": { "type": "integer" },
            "l5": { "type": "integer" }
          }
        },
        "inspectionsOosByLevel": {
          "type": "object",
          "description": "p.2 — # of Inspections out of service by level.",
          "additionalProperties": false,
          "properties": {
            "l1": { "type": "integer" }, "l2": { "type": "integer" },
            "l3": { "type": "integer" }, "l4": { "type": "integer" },
            "l5": { "type": "integer" }
          }
        },
        "totalVehiclesInspected": { "type": "integer", "description": "p.2 — Total number of vehicles inspected" },

        "inspectionThreshold": {
          "type": "object",
          "description": "p.3 — Inspection Threshold Calculation (used to verify insPctOfThresh).",
          "additionalProperties": false,
          "properties": {
            "cvsaInspectionsConducted": { "type": "integer" },
            "vehiclesInspected":        { "type": "integer" },
            "driversInspected":         { "type": "integer" },
            "totalUnitsInspected":      { "type": "integer" },
            "driverPointsAssigned":     { "type": "integer" },
            "vehiclePointsAssigned":    { "type": "integer" },
            "totalInspectionPoints":    { "type": "integer", "description": "= 0.6875 × (D + V)" },
            "setThresholdPoints":       { "type": "integer" },
            "pctOfSetThreshold":        { "type": "number" }
          }
        }
      }
    },

    "inspectionEvents": {
      "type": "array",
      "description": "Per-inspection event log (pages 4-17, 'Intervention and Event Details' section, only events of type Inspection). Drives the bottom 'CVOR Inspections' table.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cvirNumber", "inspectionDate", "level"],
        "properties": {
          "cvirNumber":      { "type": "string", "description": "p.x — CVIR # (frontend: reportNumber)" },
          "inspectionDate":  { "type": "string", "format": "date", "description": "p.x — Inspection Date" },
          "startTime":       { "type": ["string", "null"], "description": "p.x — Start Time (HH:mm)" },
          "endTime":         { "type": ["string", "null"], "description": "p.x — End Time (HH:mm)" },
          "level":           { "type": "integer", "minimum": 1, "maximum": 5, "description": "p.x — Level of Inspection" },
          "location":        { "type": ["string", "null"], "description": "p.x — Location (TIS / district)" },
          "vehiclePoints":   { "type": "integer", "description": "p.x — Vehicle Points (frontend: vehPts)" },
          "driverPoints":    { "type": "integer", "description": "p.x — Driver Points (frontend: drvPts)" },
          "cvorPoints":      { "type": "integer", "description": "Derived: vehiclePoints + driverPoints (frontend: cvorPts)" },
          "categoriesOos":   { "type": "integer", "description": "p.x — Categories OOS* (drives Status column)" },
          "totalDefects":    { "type": "integer", "description": "p.x — Total All Defects" },
          "status":          { "type": "string", "enum": ["OOS", "DEFECT", "OK"], "description": "Derived: categoriesOos>0 → OOS, else totalDefects>0 → DEFECT, else OK" },
          "driver": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name":         { "type": ["string", "null"], "description": "p.x — Driver Name (frontend: driver)" },
              "licenseNumber":{ "type": ["string", "null"], "description": "p.x — Driver Licence Number (frontend: driverLicense)" },
              "jurisdiction": { "type": ["string", "null"], "description": "p.x — Jurisdiction (under Driver)" }
            }
          },
          "vehicles": {
            "type": "array",
            "description": "1 or 2 vehicle entries per inspection.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "make":         { "type": ["string", "null"] },
                "unitNumber":   { "type": ["string", "null"], "description": "p.x — Unit Number (frontend: unit)" },
                "plate":        { "type": ["string", "null"], "description": "p.x — Vehicle Plate" },
                "jurisdiction": { "type": ["string", "null"] }
              }
            }
          },
          "defects": {
            "type": "array",
            "description": "Repeating Category/Defect rows. Asterisk on Category* flags OOS-eligible.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "category": { "type": "string", "description": "p.x — Category* (e.g. 'Vehicle Maintenance', 'Hours-of-service Compliance')" },
                "defect":   { "type": "string", "description": "p.x — Defect (e.g. 'BRAKES DEFECTIVE')" },
                "oos":      { "type": "boolean", "description": "True if Category had asterisk" },
                "points":   { "type": ["integer", "null"], "description": "Points contribution (if listed)" }
              }
            }
          }
        }
      }
    }
  }
}
